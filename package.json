{
  "name": "opencode-qfork",
  "version": "1.0.0",
  "description": "Quick fork plugin for OpenCode - fork session without git worktree",
  "type": "module",
  "main": "./qfork.ts",
  "types": "./qfork.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "dev": "bun run build && OPENCODE_CONFIG=.dev/opencode.jsonc opencode",
    "format": "eclint fix .",
    "format:check": "eclint check ."
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "fork",
    "session"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=0.13.7"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.3.2",
    "@opencode-ai/sdk": "^1.3.2",
    "@types/bun": "^1.2.0",
    "eclint": "^2.8.1",
    "typescript": "^6.0.2"
  }
}
