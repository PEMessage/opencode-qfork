# EditorConfig is awesome: https://EditorConfig.org

root = true

# TypeScript files - 4 spaces indentation
[*.{ts,tsx,mts,cts}]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# JavaScript files - 4 spaces indentation (same as TypeScript)
[*.{js,jsx,mjs,cjs}]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# JSON files - 2 spaces indentation
[*.{json,jsonc}]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Package.json and other config files
[*.config.{json,jsonc}]
indent_style = space
indent_size = 2

# Markdown and text files
[*.{md,mdx,txt}]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Shell scripts and Makefile
[{*.sh,Makefile}]
indent_style = tab
end_of_line = lf
charset = utf-8

# All other files - general settings
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
